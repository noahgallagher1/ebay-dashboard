# eBay API Credentials
# Get these from https://developer.ebay.com/my/keys
EBAY_CLIENT_ID=your_app_id_here
EBAY_CLIENT_SECRET=your_cert_id_here

# RuName from eBay Developer Portal > User Tokens
EBAY_RU_NAME=your_ru_name_here

# Set to false for production, true for sandbox testing
EBAY_SANDBOX=false

# Refresh token - obtained after first OAuth login
# Leave blank initially, fill in after first login
EBAY_REFRESH_TOKEN=

# Railway backend URL (set after Railway deployment)
# Example: https://ebay-dashboard-production.up.railway.app
RAILWAY_BACKEND_URL=https://YOUR-APP-NAME.up.railway.app

# CORS - set to your Hostinger domain
# Example: https://yourdomain.com
CORS_ORIGIN=https://yourdomain.com

# Port (Railway sets this automatically)
PORT=3000
